@startuml

skinparam Shadowing false
skinparam ArrowColor #2f4f4f
skinparam ActivityBorderColor #2f4f4f
skinparam ActivityBackgroundColor #f8f8f8
skinparam BackgroundColor white

|Преподаватель|
:Задает параметры выдачи:\n- число заданий n;\n- набор типов/групп;\n- режим распределения;

|UI|
:Проверяет корректность ввода;\nПередает параметры на сервер;

|Бэкенд Веб-сервиса|
:Формирует пул заданий Q;
:Исключает задания с некорректными ссылками зависимостей;

if (n = 1?) then (да)
  :Исключает задания\nс непустыми зависимостями;
endif

:Инициализирует пустой набор S;

while (Есть кандидаты в Q?) is (да)
  :Случайно выбирает кандидат q_i;
  :Строит замыкание зависимостей D(q_i);
  if (|S + {q_i} + D(q_i)| <= n?) then (да)
    :Добавляет q_i и D(q_i) в S;
  else (нет)
    :Пропускает q_i;
  endif
endwhile (нет)

:Вычисляет трудоемкость\nT(S) = sum t(q_i);

if (Формируется несколько билетов?) then (да)
  :Считает отклонение\n|T(S_k) - T_avg|;
  if (Отклонение выше порога?) then (да)
    :Перегенерирует выборки\nдо достижения баланса;
  else (нет)
    :Фиксирует набор билетов;
  endif
else (нет)
  :Фиксирует одиночный билет;
endif

|UI|
:Показывает итоговый состав билетов;

|Студент|
:Получает назначенный билет;

stop
@enduml
